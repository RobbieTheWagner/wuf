{
  "name": "wuf",
  "version": "0.0.0",
  "private": true,
  "description": "Talk to your dog with Ember!",
  "repository": "https://github.com/shipshapecode/wuf",
  "license": "MIT",
  "author": "Ship Shape Consulting LLC",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "cap:sync": "pnpm build && cap sync",
    "cap:android": "pnpm cap:sync && cap open android",
    "cap:ios": "pnpm cap:sync && cap open ios",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"pnpm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite",
    "test": "vite build --mode development && ember test --path dist"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/runtime": "^7.29.2",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@ember/app-tsconfig": "^1.0.3",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.2",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.2",
    "@eslint/js": "^9.39.4",
    "@glimmer/component": "^2.1.1",
    "@glint/ember-tsc": "^1.5.0",
    "@glint/template": "^1.7.7",
    "@glint/tsserver-plugin": "^2.4.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@svg-jar/plugin": "^0.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/qunit": "^2.19.13",
    "@types/rsvp": "^4.0.9",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "concurrently": "^9.2.1",
    "decorator-transforms": "^2.3.2",
    "ember-cli": "~7.0.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-deprecation-workflow": "^3.4.0",
    "ember-file-upload": "^10.1.0",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~7.0.0",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ember-template-tag": "^2.1.5",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^38.0.0",
    "tailwindcss": "^4.3.0",
    "testem": "^3.20.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11"
  },
  "engines": {
    "node": ">= 22"
  },
  "ember": {
    "edition": "octane"
  },
  "packageManager": "pnpm@10.24.0"
}
