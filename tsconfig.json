{
  "extends": "@ember/app-tsconfig",
  "include": ["app", "tests", "types"],
  "compilerOptions": {
    "allowJs": true,
    "paths": {
      "wuf/tests/*": ["./tests/*"],
      "wuf/*": ["./app/*"],
      "*": ["./types/*"]
    },
    "types": [
      "ember-source/types",
      "@embroider/core/virtual",
      "@svg-jar/plugin/client/ember",
      "vite/client",
      "@glint/ember-tsc/types"
    ]
  }
}
